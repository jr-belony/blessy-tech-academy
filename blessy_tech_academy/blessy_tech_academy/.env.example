# Example environment variables (DO NOT STORE SECRETS IN THE REPO)
# Copy this file to .env locally and set real values there.

# Django
SECRET_KEY=replace-me-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=yourdomain.com
DATABASE_URL=sqlite:///db.sqlite3
