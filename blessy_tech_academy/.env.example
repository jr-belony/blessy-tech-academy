# ================================================
# .ENV.EXAMPLE — Variables d'environnement complètes
# ================================================

SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=votre-domaine.up.railway.app
DATABASE_URL=postgres://user:pass@host:5432/dbname
SITE_URL=https://votre-domaine.up.railway.app

# IA
GEMINI_API_KEY=

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Cache
REDIS_URL=

# Stockage média (Cloudflare R2 recommandé)
USE_S3_STORAGE=True
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=auto

# Paiements
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
MONCASH_CLIENT_ID=
MONCASH_CLIENT_SECRET=
MONCASH_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Push Notifications
FIREBASE_VAPID_PUBLIC_KEY=
FIREBASE_VAPID_PRIVATE_KEY=