{% load static %}<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    <url><loc>{{ request.scheme }}://{{ request.get_host }}/</loc><priority>1.0</priority></url>
    <url><loc>{{ request.scheme }}://{{ request.get_host }}{% url 'formations' %}</loc><priority>0.9</priority></url>
    <url><loc>{{ request.scheme }}://{{ request.get_host }}{% url 'parcours' %}</loc><priority>0.8</priority></url>
    <url><loc>{{ request.scheme }}://{{ request.get_host }}{% url 'apropos' %}</loc><priority>0.7</priority></url>
    <url><loc>{{ request.scheme }}://{{ request.get_host }}{% url 'contact' %}</loc><priority>0.7</priority></url>
    <url><loc>{{ request.scheme }}://{{ request.get_host }}{% url 'ressources' %}</loc><priority>0.7</priority></url>
    {% for article in articles %}
    <url><loc>{{ request.scheme }}://{{ request.get_host }}{% url 'detail_article' article.slug %}</loc><priority>0.6</priority></url>
    {% endfor %}
</urlset>